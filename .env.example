# Basic Auth — protect the app with a shared password (leave unset to disable)
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=your-secret-password

# Hide the "Local Docker" source option (set to true on deployed servers without Docker socket)
NEXT_PUBLIC_DISABLE_LOCAL_DOCKER=false

# Path to k8s allowlist config (default: ./k8s-allowlist.yaml)
# K8S_ALLOWLIST_PATH=/etc/log-viewer/k8s-allowlist.yaml
